/* =========================================================
   Sélection compacte des TP
========================================================= */

const tpSelect = document.getElementById("tpSelect");
const openSelectedTp = document.getElementById("openSelectedTp");
const tpPreview = document.getElementById("tpPreview");

function updateTpPreview() {
    if (!tpSelect || !tpPreview) return;

    const opt = tpSelect.options[tpSelect.selectedIndex];

    if (!opt || !opt.value) {
        tpPreview.textContent = "Sélectionnez un TP pour afficher son chemin, son statut et son contenu disponible.";
        return;
    }

    tpPreview.innerHTML =
        "<strong>Statut :</strong> " + (opt.dataset.status || "") + "<br>" +
        "<strong>Chemin :</strong> " + (opt.dataset.path || "") + "<br>" +
        "<strong>Contenu :</strong> " + (opt.dataset.content || "");
}

if (tpSelect) {
    tpSelect.addEventListener("change", updateTpPreview);
}

if (openSelectedTp) {
    openSelectedTp.addEventListener("click", function () {
        if (!tpSelect || !tpSelect.value) {
            alert("Sélectionnez d’abord un TP.");
            return;
        }
        window.location.href = tpSelect.value;
    });
}

if (searchTp && tpSelect) {
    searchTp.addEventListener("input", function () {
        const q = this.value.toLowerCase().trim();

        Array.from(tpSelect.options).forEach((opt, index) => {
            if (index === 0) return;
            const text = (opt.dataset.search || opt.textContent || "").toLowerCase();
            opt.hidden = !text.includes(q);
        });
    });
}

/* =========================================================
   Sélection compacte des scripts
========================================================= */

const scriptSelect = document.getElementById("scriptSelect");
const prepareScript = document.getElementById("prepareScript");
const scriptPreview = document.getElementById("scriptPreview");
const searchScript = document.getElementById("searchScript");

function updateScriptPreview() {
    if (!scriptSelect || !scriptPreview) return;

    const opt = scriptSelect.options[scriptSelect.selectedIndex];

    if (!opt || !opt.value) {
        scriptPreview.textContent = "Sélectionnez un script pour voir son rôle, son environnement et son niveau de risque.";
        return;
    }

    scriptPreview.innerHTML =
        "<strong>Catégorie :</strong> " + (opt.dataset.category || "") + "<br>" +
        "<strong>Environnement :</strong> " + (opt.dataset.env || "") + "<br>" +
        "<strong>Risque :</strong> " + (opt.dataset.risk || "") + "<br>" +
        "<strong>Description :</strong> " + (opt.dataset.desc || "");
}

if (scriptSelect) {
    scriptSelect.addEventListener("change", updateScriptPreview);
}

if (prepareScript) {
    prepareScript.addEventListener("click", function () {
        if (!scriptSelect || !scriptSelect.value) {
            alert("Sélectionnez d’abord un script.");
            return;
        }
        window.location.href = scriptSelect.value;
    });
}

if (searchScript && scriptSelect) {
    searchScript.addEventListener("input", function () {
        const q = this.value.toLowerCase().trim();

        Array.from(scriptSelect.options).forEach((opt, index) => {
            if (index === 0) return;
            const text = (opt.dataset.search || opt.textContent || "").toLowerCase();
            opt.hidden = !text.includes(q);
        });
    });
}
