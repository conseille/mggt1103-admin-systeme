/* =========================================================
   PresentBoard MGGT1103 — JavaScript principal
   Objectif : rendre l’interface dynamique et contrôlée
========================================================= */

function goBack() {
    try {
        if (document.referrer && new URL(document.referrer).origin === window.location.origin) {
            window.history.back();
        } else {
            window.location.href = "?p=accueil";
        }
    } catch (e) {
        window.location.href = "?p=accueil";
    }
}

function exitApp() {
    const ok = confirm(
        "Voulez-vous quitter l’interface PresentBoard ?\n\n" +
        "Le serveur local peut rester actif dans WSL.\n" +
        "Vous pourrez relancer l’application avec la commande : presentboard"
    );

    if (ok) {
        window.location.href = "about:blank";
    }
}

function confirmExecution(scriptName) {
    return confirm(
        "Attention : exécution contrôlée dans WSL.\n\n" +
        "Script : " + scriptName + "\n\n" +
        "Avant de continuer, vérifiez que ce script est bien autorisé dans PresentBoard.\n\n" +
        "Un script peut :\n" +
        "- lire la structure du projet ;\n" +
        "- afficher l’état Git ;\n" +
        "- générer un journal de vérification ;\n" +
        "- afficher des erreurs à corriger.\n\n" +
        "Voulez-vous vraiment exécuter ce script ?"
    );
}

/* =========================================================
   Filtrage des travaux pratiques
========================================================= */

const searchTp = document.getElementById("searchTp");
const statusFilter = document.getElementById("statusFilter");

function filterTpCards() {
    const q = searchTp ? searchTp.value.toLowerCase().trim() : "";
    const status = statusFilter ? statusFilter.value : "";

    document.querySelectorAll(".tp-card").forEach(card => {
        const text = (card.dataset.search || card.textContent || "").toLowerCase();
        const cardStatus = card.dataset.status || "";

        const okSearch = text.includes(q);
        const okStatus = !status || cardStatus === status;

        card.style.display = okSearch && okStatus ? "" : "none";
    });
}

if (searchTp) {
    searchTp.addEventListener("input", filterTpCards);
}

if (statusFilter) {
    statusFilter.addEventListener("change", filterTpCards);
}

/* =========================================================
   Recherche dans l’explorateur de fichiers
========================================================= */

document.querySelectorAll(".search").forEach(input => {
    if (input.id === "searchTp") return;

    input.addEventListener("input", function () {
        const q = this.value.toLowerCase().trim();
        const table = document.querySelector(".files-table");

        if (!table) return;

        table.querySelectorAll("tr").forEach((row, index) => {
            if (index === 0) return;

            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(q) ? "" : "none";
        });
    });
});

/* =========================================================
   Amélioration des liens internes de l’accueil
========================================================= */

document.querySelectorAll(".action-card").forEach(card => {
    const label = card.textContent.toLowerCase();

    if (label.includes("travaux")) {
        card.style.cursor = "pointer";
        card.addEventListener("click", () => window.location.href = "?p=travaux");
    }

    if (label.includes("contrôle") || label.includes("vérification")) {
        card.style.cursor = "pointer";
        card.addEventListener("click", () => window.location.href = "?p=controle");
    }

    if (label.includes("explorateur") || label.includes("fichiers")) {
        card.style.cursor = "pointer";
        card.addEventListener("click", () => window.location.href = "?p=explorateur");
    }

    if (label.includes("outils")) {
        card.style.cursor = "pointer";
        card.addEventListener("click", () => window.location.href = "?p=outils");
    }

    if (label.includes("automatisation")) {
        card.style.cursor = "pointer";
        card.addEventListener("click", () => window.location.href = "?p=laboratoire");
    }
});

/* =========================================================
   Empêcher une double exécution trop rapide
========================================================= */

document.querySelectorAll("form").forEach(form => {
    form.addEventListener("submit", function () {
        const btn = form.querySelector("button[type='submit'], button:not([type])");

        if (btn && btn.textContent.toLowerCase().includes("exécuter")) {
            setTimeout(() => {
                btn.disabled = true;
                btn.textContent = "Exécution en cours...";
            }, 50);
        }
    });
});

