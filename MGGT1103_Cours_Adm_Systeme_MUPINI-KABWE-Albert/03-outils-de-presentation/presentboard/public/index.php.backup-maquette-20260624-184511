                $message = 'Exécution terminée. Journal créé : ' . pbRel($log, $repoRoot);
            }
        }
    }

    if ($action === 'open-vscode') {
        $target = realpath($repoRoot . '/' . ($_POST['path'] ?? ''));

        if ($target && pbInside($target, $repoRoot)) {
            shell_exec('code ' . escapeshellarg($target) . ' >/dev/null 2>&1 &');
            $message = 'Ouverture demandée dans VS Code.';
        }
    }

    if ($action === 'open-wsl') {
        shell_exec('cmd.exe /C start "" wsl.exe --cd ' . escapeshellarg($repoRoot) . ' >/dev/null 2>&1 &');
        $message = 'Ouverture WSL demandée.';
    }
