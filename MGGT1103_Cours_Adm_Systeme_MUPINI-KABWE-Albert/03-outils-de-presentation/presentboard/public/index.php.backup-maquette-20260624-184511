function h($v): string {
    return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8');
}

function pbInside(string $path, string $root): bool {
    $real = realpath($path);
    $root = realpath($root);
    return $real && $root && str_starts_with($real, $root);
}

function pbRel(string $path, string $root): string {
    $real = realpath($path);
    $root = realpath($root);
    if (!$real || !$root) return '';
    return trim(str_replace('\\', '/', substr($real, strlen($root))), '/');
}

function pbIgnored(string $path, array $ignored): bool {
    $parts = explode(DIRECTORY_SEPARATOR, $path);

    foreach ($parts as $part) {
        if (in_array($part, $ignored, true)) return true;
    }

    $name = basename($path);

    if ($name === '.gitkeep') return true;
    if (str_ends_with($name, ':Zone.Identifier')) return true;
    if (str_ends_with($name, '.tmp')) return true;
    if (str_ends_with($name, '.bak')) return true;

    return false;
}

function pbFileType(string $path): string {
    if (is_dir($path)) return 'Dossier';

    $ext = strtolower(pathinfo($path, PATHINFO_EXTENSION));

    return match ($ext) {
        'md' => 'Markdown',
        'txt' => 'Texte',
        'png', 'jpg', 'jpeg', 'webp' => 'Image',
        'sh' => 'Script Bash',
        'ps1' => 'Script PowerShell',
        'py' => 'Script Python',
        'tf' => 'Terraform',
        'docx' => 'Rapport Word',
        'pdf' => 'PDF',
        'html' => 'Page HTML',
        default => strtoupper($ext ?: 'Fichier')
    };
}

function pbIcon(string $path): string {
    if (is_dir($path)) return '📁';

    $ext = strtolower(pathinfo($path, PATHINFO_EXTENSION));

    return match ($ext) {
        'md', 'txt' => '📄',
        'png', 'jpg', 'jpeg', 'webp' => '🖼️',
        'sh', 'ps1', 'py' => '⚙️',
        'tf' => '🏗️',
        'docx', 'pdf' => '📝',
        'html' => '🌐',
        default => '📌'
    };
}

function pbUrlFile(string $path, string $repoRoot): string {
    return '?file=' . urlencode(pbRel($path, $repoRoot));
}

function pbCountFiles(string $path, array $ignored): int {
    if (!is_dir($path)) return 0;

    $count = 0;
    $it = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($path, FilesystemIterator::SKIP_DOTS)
    );

    foreach ($it as $item) {
        $p = $item->getPathname();
        if ($item->isFile() && !pbIgnored($p, $ignored)) {
            $count++;
        }
    }

    return $count;
}

function pbImmediateItems(string $folder, string $repoRoot, array $ignored): array {
    if (!is_dir($folder)) return [];

    $items = [];

    foreach (scandir($folder) ?: [] as $name) {
        if ($name === '.' || $name === '..') continue;

        $path = $folder . '/' . $name;
        if (pbIgnored($path, $ignored)) continue;

        $items[] = [
            'name' => $name,
            'path' => $path,
            'rel' => pbRel($path, $repoRoot),
            'type' => pbFileType($path),
            'icon' => pbIcon($path),
            'is_dir' => is_dir($path),
            'is_script' => preg_match('/\.(sh|ps1|py)$/i', $path) === 1,
            'modified' => date('Y-m-d H:i', filemtime($path)),
            'url' => pbUrlFile($path, $repoRoot)
        ];
    }

    usort($items, function ($a, $b) {
        if ($a['is_dir'] !== $b['is_dir']) return $a['is_dir'] ? -1 : 1;
        return strcasecmp($a['name'], $b['name']);
    });

    return $items;
}

function pbDetectTPs(string $courseRoot): array {
    $tpRoot = $courseRoot . '/01-travaux-pratiques';

    if (!is_dir($tpRoot)) return [];

    $tps = [];

    foreach (glob($tpRoot . '/TP*', GLOB_ONLYDIR) ?: [] as $tp) {
        $tps[] = [
            'name' => basename($tp),
            'title' => str_replace(['-', '_'], ' ', basename($tp)),
            'path' => $tp
        ];
    }

    usort($tps, fn($a, $b) => strcasecmp($a['name'], $b['name']));

    return $tps;
}

function pbSections(string $tpPath, string $repoRoot, array $ignored): array {
    $expected = [
        'Rapport' => ['rapport', 'rapports'],
        'Captures' => ['captures', 'capture'],
        'Résultats' => ['resultats', 'résultats'],
        'Scripts' => ['scripts'],
        'Rendu final' => ['rendu-final', 'rendu_final', 'rendu']
    ];

    $sections = [];

    foreach ($expected as $label => $aliases) {
        $found = null;

        foreach ($aliases as $alias) {
            $candidate = $tpPath . '/' . $alias;
            if (is_dir($candidate)) {
                $found = $candidate;
                break;
            }
        }

        $count = $found ? pbCountFiles($found, $ignored) : 0;

        $sections[] = [
            'label' => $label,
            'path' => $found,
            'exists' => $found !== null,
            'count' => $count,
            'items' => $found ? pbImmediateItems($found, $repoRoot, $ignored) : []
        ];
    }

    return $sections;
}

function pbTpStatus(string $tpPath, array $sections, array $ignored): string {
    $total = pbCountFiles($tpPath, $ignored);

    if ($total === 0) return 'Non commencé';

    $map = [];
    foreach ($sections as $s) {
        $map[$s['label']] = $s['count'];
    }

    $rapport = ($map['Rapport'] ?? 0) > 0;
    $captures = ($map['Captures'] ?? 0) > 0;
    $resultats = ($map['Résultats'] ?? 0) > 0;
    $rendu = ($map['Rendu final'] ?? 0) > 0;

    if ($rapport && $captures && $resultats && $rendu) return 'Complet';
    if ($rapport && ($captures || $resultats || $rendu)) return 'À vérifier';

    return 'Incomplet';
}

function pbStatusClass(string $status): string {
    return match ($status) {
        'Complet' => 'ok',
        'À vérifier' => 'warn',
        'Incomplet' => 'err',
        'Non commencé' => 'neutral',
        default => 'neutral'
    };
}

function pbTree(string $dir, string $repoRoot, array $ignored, int $depth = 0, int $max = 4): string {
    if (!is_dir($dir) || $depth > $max) return '';

    $items = [];

    foreach (scandir($dir) ?: [] as $name) {
        if ($name === '.' || $name === '..') continue;

        $path = $dir . '/' . $name;
        if (pbIgnored($path, $ignored)) continue;

        $items[] = $path;
    }

    usort($items, function ($a, $b) {
        if (is_dir($a) !== is_dir($b)) return is_dir($a) ? -1 : 1;
        return strcasecmp(basename($a), basename($b));
    });

    $html = '<ul class="tree">';

    foreach ($items as $path) {
        $html .= '<li>';

        if (is_dir($path)) {
            $html .= '<a href="?p=explorateur&dir=' . urlencode(pbRel($path, $repoRoot)) . '">📁 ' . h(basename($path)) . '</a>';
            $html .= pbTree($path, $repoRoot, $ignored, $depth + 1, $max);
        } else {
            $html .= '<a href="' . h(pbUrlFile($path, $repoRoot)) . '"> ' . h(pbIcon($path)) . ' ' . h(basename($path)) . '</a>';
        }

        $html .= '</li>';
    }

    $html .= '</ul>';

    return $html;
}

function pbGit(string $repoRoot, string $cmd): string {
    return shell_exec('cd ' . escapeshellarg($repoRoot) . ' && ' . $cmd . ' 2>&1') ?? '';
}

function pbLoadManifest(string $pbDir): array {
    $file = $pbDir . '/automation/manifest.json';

    if (!is_file($file)) return [];

    $data = json_decode(file_get_contents($file), true);

    return $data['scripts'] ?? [];
}

function pbSaveLog(string $pbDir, string $id, string $content): string {
    $dir = $pbDir . '/automation/logs';

    if (!is_dir($dir)) mkdir($dir, 0777, true);

    $file = $dir . '/execution-' . preg_replace('/[^a-zA-Z0-9_-]/', '-', $id) . '-' . date('Ymd-His') . '.log';

    file_put_contents($file, $content);

    return $file;
}

