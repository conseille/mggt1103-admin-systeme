    $action = $_POST['action'] ?? '';

    if ($action === 'run-script') {
        $scriptId = $_POST['script_id'] ?? '';
        $script = null;

        foreach ($manifest as $s) {
            if (($s['id'] ?? '') === $scriptId) {
                $script = $s;
                break;
            }
