if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $action = $_POST['action'] ?? '';

    if ($action === 'run-script') {
        $scriptId = $_POST['script_id'] ?? '';
        $script = null;

        foreach ($manifest as $s) {
            if (($s['id'] ?? '') === $scriptId) {
                $script = $s;
                break;
            }
        }

        if (!$script) {
            $message = 'Script non autorisé.';
        } else {
            $scriptPath = realpath($pbDir . '/' . $script['script']);
            $allowed = realpath($pbDir . '/automation/scripts');

            if (!$scriptPath || !$allowed || !pb_inside($scriptPath, $allowed)) {
                $message = 'Script bloqué : chemin non autorisé.';
            } else {
                $executionOutput = shell_exec('cd ' . escapeshellarg($repoRoot) . ' && bash ' . escapeshellarg($scriptPath) . ' 2>&1') ?? '';
                $log = pb_save_log($pbDir, $scriptId, $executionOutput);
                $message = 'Exécution terminée. Journal créé : ' . pb_rel($log, $repoRoot);
            }
        }
    }

    if ($action === 'open-vscode') {
        $target = realpath($repoRoot . '/' . ($_POST['path'] ?? ''));

        if ($target && pb_inside($target, $repoRoot)) {
            shell_exec('code ' . escapeshellarg($target) . ' >/dev/null 2>&1 &');
            $message = 'Ouverture demandée dans VS Code.';
        }
    }

    if ($action === 'open-wsl') {
        shell_exec('cmd.exe /C start "" wsl.exe --cd ' . escapeshellarg($repoRoot) . ' >/dev/null 2>&1 &');
        $message = 'Ouverture WSL demandée.';
    }
}

