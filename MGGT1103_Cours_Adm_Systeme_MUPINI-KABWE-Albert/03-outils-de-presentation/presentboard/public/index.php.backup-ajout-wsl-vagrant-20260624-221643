function h(mixed $v): string { return htmlspecialchars((string)$v, ENT_QUOTES, 'UTF-8'); }

function pb_inside(string $path, string $root): bool {
    $real = realpath($path);
    $rootReal = realpath($root);
    return is_string($real) && is_string($rootReal) && str_starts_with($real, $rootReal);
}

function pb_rel(string $path, string $root): string {
    $real = realpath($path);
    $rootReal = realpath($root);
    if (!is_string($real) || !is_string($rootReal)) return '';
    return trim(str_replace('\\', '/', substr($real, strlen($rootReal))), '/');
}

function pb_ignored(string $path, array $ignored): bool {
    foreach (explode(DIRECTORY_SEPARATOR, $path) as $part) {
        if (in_array($part, $ignored, true)) return true;
    }

    $name = basename($path);

    return $name === '.gitkeep'
        || str_ends_with($name, ':Zone.Identifier')
        || str_ends_with($name, '.tmp')
        || str_ends_with($name, '.bak')
        || str_ends_with($name, '~');
}

function pb_type(string $path): string {
    if (is_dir($path)) return 'Dossier';

    $ext = strtolower(pathinfo($path, PATHINFO_EXTENSION));

    return match ($ext) {
        'md' => 'Markdown',
        'txt' => 'Texte',
        'png', 'jpg', 'jpeg', 'webp' => 'Image',
        'sh' => 'Script Bash',
        'ps1' => 'Script PowerShell',
        'py' => 'Script Python',
        'tf' => 'Terraform',
        'docx' => 'Rapport Word',
        'pdf' => 'PDF',
        'html' => 'Page HTML',
        'json' => 'JSON',
        'css' => 'CSS',
        'js' => 'JavaScript',
        default => strtoupper($ext ?: 'Fichier')
    };
}

function pb_icon(string $path): string {
    if (is_dir($path)) return '📁';

    $ext = strtolower(pathinfo($path, PATHINFO_EXTENSION));

    return match ($ext) {
        'md', 'txt' => '📄',
        'png', 'jpg', 'jpeg', 'webp' => '🖼️',
        'sh', 'ps1', 'py' => '⚙️',
        'tf' => '🏗️',
        'docx', 'pdf' => '📝',
        'html' => '🌐',
        'json' => '🔧',
        default => '📌'
    };
}

function pb_file_url(string $path, string $repoRoot): string {
    return '?file=' . urlencode(pb_rel($path, $repoRoot));
}

function pb_file_count(string $dir, array $ignored): int {
    if (!is_dir($dir)) return 0;

    $count = 0;

    $it = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($dir, FilesystemIterator::SKIP_DOTS)
    );

    foreach ($it as $item) {
        $p = $item->getPathname();

        if ($item->isFile() && !pb_ignored($p, $ignored)) {
            $count++;
        }
    }

    return $count;
}

function pb_items(string $dir, string $repoRoot, array $ignored): array {
    if (!is_dir($dir)) return [];

    $items = [];

    foreach (scandir($dir) ?: [] as $name) {
        if ($name === '.' || $name === '..') continue;

        $path = $dir . '/' . $name;

        if (pb_ignored($path, $ignored)) continue;

        $items[] = [
            'name' => $name,
            'path' => $path,
            'rel' => pb_rel($path, $repoRoot),
            'type' => pb_type($path),
            'icon' => pb_icon($path),
            'is_dir' => is_dir($path),
            'is_script' => preg_match('/\.(sh|ps1|py)$/i', $path) === 1,
            'modified' => date('Y-m-d H:i', filemtime($path)),
            'url' => pb_file_url($path, $repoRoot)
        ];
    }

    usort($items, function ($a, $b) {
        if ($a['is_dir'] !== $b['is_dir']) return $a['is_dir'] ? -1 : 1;
        return strcasecmp($a['name'], $b['name']);
    });

    return $items;
}

function pb_detect_tps(string $courseRoot): array {
    $tpRoot = $courseRoot . '/01-travaux-pratiques';

    if (!is_dir($tpRoot)) return [];

    $tps = [];

    foreach (glob($tpRoot . '/TP*', GLOB_ONLYDIR) ?: [] as $tp) {
        $tps[] = [
            'name' => basename($tp),
            'title' => str_replace(['-', '_'], ' ', basename($tp)),
            'path' => $tp
        ];
    }

    usort($tps, fn($a, $b) => strcasecmp($a['name'], $b['name']));

    return $tps;
}

function pb_sections(string $tpPath, string $repoRoot, array $ignored): array {
    $expected = [
        'Rapport' => ['rapport', 'rapports'],
        'Captures' => ['captures', 'capture'],
        'Résultats' => ['resultats', 'résultats'],
        'Scripts' => ['scripts'],
        'Rendu final' => ['rendu-final', 'rendu_final', 'rendu']
    ];

    $sections = [];

    foreach ($expected as $label => $aliases) {
        $found = null;

        foreach ($aliases as $alias) {
            $candidate = $tpPath . '/' . $alias;

            if (is_dir($candidate)) {
                $found = $candidate;
                break;
            }
        }

        $count = $found ? pb_file_count($found, $ignored) : 0;

        $sections[] = [
            'label' => $label,
            'path' => $found,
            'exists' => $found !== null,
            'count' => $count,
            'items' => $found ? pb_items($found, $repoRoot, $ignored) : []
        ];
    }

    return $sections;
}

function pb_tp_status(string $tpPath, array $sections, array $ignored): string {
    if (pb_file_count($tpPath, $ignored) === 0) return 'Non commencé';

    $map = [];

    foreach ($sections as $s) {
        $map[$s['label']] = $s['count'];
    }

    $rapport = ($map['Rapport'] ?? 0) > 0;
    $captures = ($map['Captures'] ?? 0) > 0;
    $resultats = ($map['Résultats'] ?? 0) > 0;
    $rendu = ($map['Rendu final'] ?? 0) > 0;

    if ($rapport && $captures && $resultats && $rendu) return 'Complet';
    if ($rapport && ($captures || $resultats || $rendu)) return 'À vérifier';

    return 'Incomplet';
}

function pb_status_class(string $status): string {
    return match ($status) {
        'Complet' => 'ok',
        'À vérifier' => 'warn',
        'Incomplet' => 'err',
        'Non commencé' => 'neutral',
        default => 'neutral'
    };
}

function pb_tree(string $dir, string $repoRoot, array $ignored, int $depth = 0, int $max = 4): string {
    if (!is_dir($dir) || $depth > $max) return '';

    $items = [];

    foreach (scandir($dir) ?: [] as $name) {
        if ($name === '.' || $name === '..') continue;

        $path = $dir . '/' . $name;

        if (pb_ignored($path, $ignored)) continue;

        $items[] = $path;
    }

    usort($items, function ($a, $b) {
        if (is_dir($a) !== is_dir($b)) return is_dir($a) ? -1 : 1;
        return strcasecmp(basename($a), basename($b));
    });

    $html = '<ul class="tree">';

    foreach ($items as $path) {
        $html .= '<li>';

        if (is_dir($path)) {
            $html .= '<a href="?p=explorateur&dir=' . urlencode(pb_rel($path, $repoRoot)) . '">📁 ' . h(basename($path)) . '</a>';
            $html .= pb_tree($path, $repoRoot, $ignored, $depth + 1, $max);
        } else {
            $html .= '<a href="' . h(pb_file_url($path, $repoRoot)) . '">' . h(pb_icon($path)) . ' ' . h(basename($path)) . '</a>';
        }

        $html .= '</li>';
    }

    $html .= '</ul>';

    return $html;
}

function pb_git(string $repoRoot, string $cmd): string {
    return shell_exec('cd ' . escapeshellarg($repoRoot) . ' && ' . $cmd . ' 2>&1') ?? '';
}

function pb_manifest(string $pbDir): array {
    $file = $pbDir . '/automation/manifest.json';

    if (!is_file($file)) return [];

    $data = json_decode((string)file_get_contents($file), true);

    return is_array($data) ? ($data['scripts'] ?? []) : [];
}

function pb_save_log(string $pbDir, string $id, string $content): string {
    $dir = $pbDir . '/automation/logs';

    if (!is_dir($dir)) mkdir($dir, 0777, true);

    $file = $dir . '/execution-' . preg_replace('/[^a-zA-Z0-9_-]/', '-', $id) . '-' . date('Ymd-His') . '.log';

    file_put_contents($file, $content);

    return $file;
}

